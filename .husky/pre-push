#!/bin/sh
. ~/.nvm/nvm.sh 2>/dev/null || true
cd "$(git rev-parse --show-toplevel)"
# Regla global (2026-06-20): el pre-push corre los mismos checks que el CI para
# no romper nada. Build de producción + suite unitaria completa (ng test).
npx ng build --configuration production 2>&1 || exit 1
npx ng test --watch=false 2>&1 || exit 1
