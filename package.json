{
  "name": "front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:staging": "ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --ci --coverage",
    "test:watch": "ng test --watch",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:ci": "npx playwright test --reporter=list",
    "e2e:smoke": "npx playwright test e2e/completar-test-practica e2e/completar-flashcards e2e/realizar-simulacro-alumno --reporter=list",
    "test:all": "pnpm test:ci && pnpm e2e:ci",
    "prepare": "husky || true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.11",
    "@angular/common": "^18.1.0",
    "@angular/compiler": "^18.1.0",
    "@angular/core": "^18.1.0",
    "@angular/forms": "^18.1.0",
    "@angular/platform-browser": "^18.1.0",
    "@angular/platform-browser-dynamic": "^18.1.0",
    "@angular/router": "^18.1.0",
    "@fortawesome/fontawesome-free": "^6.6.0",
    "@ngrx/effects": "^18.1.1",
    "@ngrx/store": "^18.1.1",
    "@ngrx/store-devtools": "^18.1.1",
    "@toast-ui/editor": "^3.2.2",
    "angular-calendar": "^0.31.1",
    "angular-draggable-droppable": "^8.0.0",
    "chart.js": "^3.9.1",
    "chartjs-plugin-annotation": "^2.2.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
    "echarts": "^5.5.1",
    "lodash": "^4.17.21",
    "lodash-decorators": "^6.0.1",
    "marked": "^14.1.1",
    "ngx-echarts": "^18.0.0",
    "ngx-markdown": "^18.0.0",
    "ngx-spinner": "^17.0.0",
    "ngx-toastr": "^19.0.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^17.18.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-builders/jest": "^18.0.0",
    "@angular-devkit/build-angular": "^18.1.4",
    "@angular/cli": "^18.1.4",
    "@angular/compiler-cli": "^18.1.0",
    "@angular/localize": "^18.1.4",
    "@playwright/test": "^1.58.2",
    "@types/echarts": "^4.9.22",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.7",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.5.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ],
    "src/**/*.html": [
      "prettier --write"
    ],
    "src/**/*.scss": [
      "prettier --write"
    ]
  }
}
